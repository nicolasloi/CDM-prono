---
const { delta = 0 } = Astro.props;
const up = delta > 0, down = delta < 0;
const color = up ? 'var(--green)' : down ? 'var(--red)' : 'var(--text-dim)';
const sym = up ? '▲' : down ? '▼' : '–';
---
<span style={`color:${color};font-size:11px;font-weight:800`} title={`${delta} place(s)`}>
  {sym}{delta !== 0 ? Math.abs(delta) : ''}
</span>
