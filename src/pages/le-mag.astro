---
import Base from '../layouts/Base.astro';
import RaceChart from '../components/RaceChart.astro';
import OtherGroups from '../components/OtherGroups.astro';
import Badges from '../components/Badges.astro';
import HeadToHead from '../components/HeadToHead.astro';
import { getLatest, getTimeseries } from '../data';
import { biggestClimber, badges } from '../../scripts/lib/stats.mjs';

const latest = getLatest();
const ts = getTimeseries();
const climber = biggestClimber(ts);
const allBadges = badges(ts);
if (climber.name && climber.gain > 0) allBadges.unshift({ label: 'Roi du dernier relevé', name: climber.name, hint: `+${climber.gain} pts` });
const h2hMembers = latest.members.map((m) => ({ name: m.name, totalPoints: m.totalPoints }));
---
<Base title="Le Mag">
  <p class="kicker">★ Stats & data</p>
  <h1 class="h1">Le <em>Mag</em></h1>
  <div style="display:flex;flex-direction:column;gap:16px;margin-top:16px">
    <RaceChart ts={ts} experts={latest.experts} />
    <Badges items={allBadges} />
    <HeadToHead members={h2hMembers} />
    <OtherGroups groups={latest.otherGroups} />
  </div>
</Base>
