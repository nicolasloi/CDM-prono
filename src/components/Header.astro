---
const base = import.meta.env.BASE_URL;
const home = `${base}/`.replace(/\/{2,}/g, '/');
const matchsHref = `${home}matchs`.replace(/\/{2,}/g, '/');
const bracketHref = `${home}bracket`.replace(/\/{2,}/g, '/');
---
<header style="position:relative;z-index:2;border-bottom:1px solid var(--line);backdrop-filter:blur(8px)">
  <div class="container" style="display:flex;gap:16px;align-items:center;padding:16px 0">
    <a href={home} style="text-decoration:none;font-weight:900;font-size:19px;letter-spacing:-.02em;display:flex;align-items:center;gap:8px">
      <span style="display:inline-block;width:10px;height:10px;border-radius:3px;background:linear-gradient(135deg,var(--red),var(--green) 50%,var(--blue))"></span>
      CDM <span style="color:var(--gold)">Prono</span>
    </a>
    <nav style="display:flex;gap:16px;font-size:14px;font-weight:700">
      <a href={home} style="text-decoration:none;color:var(--text-dim)">Classement</a>
      <a href={matchsHref} style="text-decoration:none;color:var(--text-dim)">Matchs</a>
      <a href={bracketHref} style="text-decoration:none;color:var(--text-dim)">Tableau</a>
    </nav>
  </div>
</header>
