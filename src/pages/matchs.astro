---
import Base from '../layouts/Base.astro';
import matchesData from '../../data/matches.json';

const all = matchesData.matches as any[];

// Regroupe par jour (le plus récent d'abord), libellé "jeudi 19 juin".
function dayKey(m: any) { return (m.date || '').split(' | ')[0]; }
function dayLabel(m: any) {
  try {
    const d = new Date(m.kickoff).toLocaleDateString('fr-CH', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'Europe/Zurich' });
    return d;
  } catch { return dayKey(m); }
}
function hour(m: any) { return (m.date || '').split(' | ')[1] || ''; }

const groups: { key: string; label: string; matches: any[] }[] = [];
for (const m of all) {
  const k = dayKey(m);
  let g = groups.find((x) => x.key === k);
  if (!g) { g = { key: k, label: dayLabel(m), matches: [] }; groups.push(g); }
  g.matches.push(m);
}
let gi = 0;
---
<Base title="Matchs">
  <section class="hero2">
    <p class="kicker">★ Qui a misé quoi</p>
    <h1 class="h1">Les <em>Matchs</em></h1>
    <p class="dim lede">Chaque match et le prono de chaque membre. Dès le coup d'envoi, les pronos apparaissent et le match passe « en cours ».</p>
  </section>

  <div class="bar">
    <div class="seg" role="tablist">
      <button class="on" data-filter="all">Tous</button>
      <button data-filter="live"><span class="ld"></span>En cours <span class="cnt" id="cnt-live">0</span></button>
      <button data-filter="done">Terminés</button>
    </div>
    <div class="legend">
      <span><i class="lg gold"></i>prono</span>
      <span><i class="lg grn"></i>points</span>
      <span>★ exact</span>
      <span>👑 meilleur</span>
    </div>
  </div>

  {groups.map((g) => (
    <section class="day">
      <h2 class="day-h">{g.label}</h2>
      {g.matches.map((m) => {
        const hasScore = m.actualHome != null && m.actualAway != null;
        const exactOf = (p: any) => hasScore && p.predHome === m.actualHome && p.predAway === m.actualAway;
        const homeWin = hasScore && m.actualHome > m.actualAway, awayWin = hasScore && m.actualAway > m.actualHome;
        const maxPts = Math.max(0, ...m.picks.map((p: any) => p.points || 0));
        const d = (gi++ % 6) * 45;
        return (
          <article class={`mx${hasScore ? '' : ' islive'}`} data-kickoff={m.kickoff} data-hour={hour(m)} data-state={hasScore ? 'done' : 'live'} style={`--d:${d}ms`}>
            <div class="mx-glow" aria-hidden="true"></div>
            <header class="mx-top">
              <div class={`mx-team${homeWin ? ' win' : ''}`}><span class="fl">{m.homeFlag}</span><span class="tn">{m.home}</span></div>
              <div class="mx-score">
                <b>{hasScore ? m.actualHome : '–'}</b><span class="sep">:</span><b>{hasScore ? m.actualAway : '–'}</b>
                <span class="mx-status">{hasScore
                  ? <span class="st-time">{hour(m)}</span>
                  : <span class="st-live"><span class="dot"></span>EN COURS</span>}</span>
              </div>
              <div class={`mx-team r${awayWin ? ' win' : ''}`}><span class="tn">{m.away}</span><span class="fl">{m.awayFlag}</span></div>
            </header>
            <div class="mx-stad">{m.stadium}</div>
            <div class="mx-picks">
              {m.picks.map((p: any) => {
                const ok = p.points > 0;
                const isBest = maxPts > 0 && p.points === maxPts;
                return (
                  <div class={`px${ok ? '' : ' z'}${isBest ? ' best' : ''}${exactOf(p) ? ' exact' : ''}`}>
                    {isBest && <span class="crown">👑</span>}
                    <span class="px-n">{p.name}</span>
                    <span class="px-s">{p.predHome}<i>·</i>{p.predAway}</span>
                    <span class="px-pt">{ok ? '+' + p.points : '—'}{exactOf(p) ? ' ★' : ''}</span>
                  </div>
                );
              })}
            </div>
          </article>
        );
      })}
    </section>
  ))}

  {all.length === 0 && <p class="dim">Les matchs s'afficheront ici dès les premiers coups d'envoi.</p>}

  <script>
    // « En cours » = match révélé sans résultat final (data-state calculé au build).
    // Dès que le score est connu, le match passe « terminé » — pas de minuteur.
    // « En cours » = match révélé sans résultat final. Garde-fou : passé ~2h30
    // après le coup d'envoi, le match est forcément terminé (même si le score
    // n'a pas encore été re-capté) → on enlève le badge « en cours ».
    const MAXLIVE = 2.5 * 3600 * 1000;
    const now = Date.now();
    const cards = Array.from(document.querySelectorAll('.mx'));
    let live = 0;
    cards.forEach((c) => {
      if (c.dataset.state !== 'live') return;
      const ko = Date.parse(c.dataset.kickoff || '');
      if (!Number.isNaN(ko) && now > ko + MAXLIVE) {
        c.dataset.state = 'done';
        c.classList.remove('islive');
        const st = c.querySelector('.mx-status');
        if (st) st.innerHTML = '<span class="st-time">' + (c.dataset.hour || '') + '</span>';
      } else {
        live++;
      }
    });
    const cl = document.getElementById('cnt-live');
    if (cl) cl.textContent = String(live);

    // Révélation au scroll (stagger via --d)
    if (matchMedia('(prefers-reduced-motion: no-preference)').matches) {
      const io = new IntersectionObserver((ents) => {
        ents.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { rootMargin: '0px 0px -8% 0px' });
      cards.forEach((c) => io.observe(c));
    } else {
      cards.forEach((c) => c.classList.add('in'));
    }

    // Filtre
    const days = Array.from(document.querySelectorAll('.day'));
    function apply(f) {
      cards.forEach((c) => { c.style.display = (f === 'all' || c.dataset.state === f) ? '' : 'none'; });
      days.forEach((d) => { d.style.display = d.querySelector('.mx:not([style*="display: none"])') ? '' : 'none'; });
    }
    document.querySelectorAll('.seg button').forEach((b) => {
      b.addEventListener('click', () => {
        document.querySelectorAll('.seg button').forEach((x) => x.classList.remove('on'));
        b.classList.add('on');
        apply(b.dataset.filter);
      });
    });
  </script>

  <style is:global>
    .hero2 { padding: 18px 0 12px; }
    .lede { font-size: 13px; margin-top: 6px; max-width: 60ch; }

    /* Barre filtre + légende (collante) */
    .bar { position: sticky; top: 0; z-index: 20; display: flex; align-items: center; justify-content: space-between; gap: 14px; flex-wrap: wrap;
      padding: 12px 0; margin-bottom: 8px; background: color-mix(in srgb, var(--bg) 86%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid var(--line); }
    .seg { display: inline-flex; background: var(--surface); border: 1px solid var(--line); border-radius: 30px; padding: 3px; }
    .seg button { border: 0; background: none; color: var(--text-dim); font: 700 13px var(--font); padding: 7px 14px; border-radius: 24px; cursor: pointer; display: inline-flex; align-items: center; gap: 7px; transition: color .15s, background .15s; }
    .seg button.on { background: var(--gold); color: #1a1407; }
    .seg .ld { width: 7px; height: 7px; border-radius: 50%; background: var(--red); }
    .seg .cnt { font-size: 11px; opacity: .8; }
    .legend { display: flex; gap: 14px; font-size: 11px; color: var(--text-dim); flex-wrap: wrap; }
    .legend i.lg { display: inline-block; width: 9px; height: 9px; border-radius: 3px; margin-right: 5px; vertical-align: middle; }
    .legend .gold { background: var(--gold); } .legend .grn { background: #51e39a; }
    @media (max-width: 640px) { .legend { display: none; } }

    /* En-tête de jour */
    .day { margin-top: 10px; }
    .day-h { position: sticky; top: 54px; z-index: 10; font: 800 11px/1 var(--font); letter-spacing: .22em; text-transform: uppercase; color: var(--gold);
      margin: 22px 0 12px; padding: 8px 0; }
    .day-h::after { content: ''; display: block; height: 1px; background: linear-gradient(90deg, var(--gold-soft), transparent); margin-top: 8px; }

    /* Carte match */
    .mx { position: relative; background: var(--surface); border: 1px solid var(--line); border-radius: 20px; padding: 18px 20px; margin-bottom: 14px; overflow: hidden; transition: transform .18s ease, border-color .18s ease; }
    @media (prefers-reduced-motion: no-preference) {
      .mx { opacity: 0; transform: translateY(18px); transition: opacity .55s cubic-bezier(.2,.7,.2,1), transform .55s cubic-bezier(.2,.7,.2,1), border-color .18s; transition-delay: var(--d, 0ms); }
      .mx.in { opacity: 1; transform: none; }
    }
    .mx:hover { transform: translateY(-3px); border-color: var(--gold-soft); }
    .mx-glow { position: absolute; inset: -1px; border-radius: 20px; pointer-events: none; opacity: 0; transition: opacity .3s; background: radial-gradient(120% 90% at 50% -20%, var(--gold-soft), transparent 55%); }
    .mx:hover .mx-glow { opacity: 1; }
    .mx.islive { border-color: rgba(227,52,47,.55); box-shadow: 0 0 50px -20px var(--red); }
    .mx.islive .mx-glow { opacity: 1; background: radial-gradient(120% 90% at 50% -20%, rgba(227,52,47,.18), transparent 55%); }

    .mx-top { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 12px; position: relative; }
    .mx-team { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: clamp(15px, 2.1vw, 20px); color: var(--text-dim); min-width: 0; }
    .mx-team.win { color: var(--text); }
    .mx-team.r { justify-content: flex-end; text-align: right; }
    .mx-team .fl { font-size: 26px; line-height: 1; filter: drop-shadow(0 2px 4px rgba(0,0,0,.4)); }
    .mx-team .tn { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .mx-score { text-align: center; line-height: 1; }
    .mx-score b { font-weight: 900; font-size: clamp(26px, 5vw, 40px); letter-spacing: -.02em; }
    .mx-score .sep { color: var(--text-dim); margin: 0 8px; font-weight: 800; font-size: clamp(20px, 4vw, 30px); vertical-align: 3px; }
    .mx-status { display: block; margin-top: 4px; }
    .st-time { font-size: 11px; color: var(--text-dim); font-weight: 700; }
    .st-live { font: 800 10px/1 var(--font); letter-spacing: .14em; color: var(--red); display: inline-flex; align-items: center; gap: 5px; }
    .st-live .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--red); animation: pulse 1.1s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: .3; transform: scale(.7); } }
    .mx-stad { text-align: center; font-size: 11px; color: var(--text-dim); margin: 10px 0 16px; }

    .mx-picks { display: grid; grid-template-columns: repeat(auto-fill, minmax(176px, 1fr)); gap: 8px; }
    .px { position: relative; display: flex; align-items: center; gap: 8px; background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 9px 12px; transition: transform .12s ease, border-color .12s; }
    .px:hover { transform: translateY(-1px); }
    .px.z { opacity: .62; }
    .px.exact { border-color: var(--gold-soft); }
    .px.best { border-color: var(--gold); background: linear-gradient(100deg, var(--gold-soft), var(--bg) 70%); opacity: 1; }
    .px .crown { position: absolute; top: -9px; left: -6px; font-size: 14px; transform: rotate(-18deg); filter: drop-shadow(0 2px 3px rgba(0,0,0,.5)); }
    .px-n { flex: 1; font-weight: 600; font-size: 13px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .px-s { font-weight: 900; color: var(--gold); font-size: 15px; }
    .px-s i { color: var(--text-dim); font-style: normal; margin: 0 3px; }
    .px-pt { font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 16px; background: rgba(0,168,90,.18); color: #51e39a; white-space: nowrap; }
    .px.z .px-pt { background: var(--surface-hi); color: var(--text-dim); }
  </style>
</Base>
