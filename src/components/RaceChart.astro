---
import { linePath } from '../../scripts/lib/svg.mjs';
import { accentFor } from '../../scripts/lib/members.mjs';
const { ts, experts = [] } = Astro.props;
const W = 640, H = 260;
const series = Object.values(ts).filter((s) => s.length > 1);
const allPts = series.flatMap((s) => s.map((p) => p.totalPoints));
const min = Math.min(...allPts, 0);
const max = Math.max(...allPts, ...(experts.length ? experts : [1]));
const lines = series.map((s, i) => ({
  name: s.at(-1).name, color: accentFor(i),
  d: linePath(s.map((p) => p.totalPoints), { width: W, height: H, min, max }),
  end: { y: (1 - (s.at(-1).totalPoints - min) / (max - min || 1)) * H, v: s.at(-1).totalPoints },
}));
const expertY = experts.length ? (1 - (Math.max(...experts) - min) / (max - min || 1)) * H : null;
---
<div class="pill" style="padding:16px;overflow:hidden">
  <p class="kicker" style="margin-bottom:10px">La course en tête</p>
  {series.length === 0 ? (
    <p class="dim" style="font-size:13px;padding:24px 0;text-align:center">Les courbes apparaîtront après quelques relevés. 📈</p>
  ) : (
    <svg viewBox={`0 0 ${W + 80} ${H + 20}`} style="width:100%;height:auto">
      {expertY !== null && (
        <g>
          <line x1="0" y1={expertY} x2={W} y2={expertY} stroke="var(--text-dim)" stroke-dasharray="4 4" stroke-width="1"/>
          <text x={W + 4} y={expertY + 4} fill="var(--text-dim)" font-size="10">experts</text>
        </g>
      )}
      {lines.map((l) => (
        <g>
          <path d={l.d} fill="none" stroke={l.color} stroke-width="2.5" stroke-linejoin="round"/>
          <circle cx={W} cy={l.end.y} r="3" fill={l.color}/>
          <text x={W + 6} y={l.end.y + 4} fill={l.color} font-size="11" font-weight="700">{l.name} {l.end.v}</text>
        </g>
      ))}
    </svg>
  )}
  <p class="dim" style="font-size:11px;margin-top:8px">Points cumulés au fil des relevés.</p>
</div>
