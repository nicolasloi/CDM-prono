---
import { shortName } from '../../scripts/lib/members.mjs';
import { flagFor } from '../../scripts/lib/flags.mjs';
// rounds: [{ name, ties: [match | fixture(upcoming) | {placeholder}] }]
const { rounds = [] } = Astro.props;
const fl = (t: string) => flagFor(t);
---
<div class="bracket">
  <svg class="bk-links" aria-hidden="true"><path /></svg>
  {rounds.map((r: any, ri: number) => (
    <div class="bk-round">
      <p class="bk-rk">{r.name}</p>
      <div class="bk-ties">
        {r.ties.map((t: any, si: number) => {
          if (t.placeholder) return <div class="bk-tie ph" data-r={ri} data-s={si}><span class="bk-ph">{r.date || 'à venir'}</span></div>;
          const played = t.actualHome != null && t.actualAway != null;
          const draw = played && t.actualHome === t.actualAway;
          const penW = t.penHome != null && t.penAway != null ? (t.penAway > t.penHome ? 'away' : 'home') : null;
          const homeW = played && (t.actualHome > t.actualAway || (draw && penW === 'home'));
          const awayW = played && (t.actualAway > t.actualHome || (draw && penW === 'away'));
          // Éliminée = l'équipe a perdu N'IMPORTE QUEL match de la phase finale (calculé sur tout
          // le tableau, cf. bracket.mjs) → estompe TOUT son parcours, y compris ses victoires des
          // tours précédents. Les deux classes se cumulent : une victoire d'une équipe depuis
          // éliminée garde une touche dorée (on voit qu'elle avait gagné CE match) mais estompée
          // (cf. .lost.w), différente à la fois du doré plein (encore en lice) et du gris plat
          // (a perdu CE match précis).
          const homeElim = !!t.homeOut, awayElim = !!t.awayOut;
          const maxPts = Math.max(0, ...(t.picks || []).map((p: any) => p.points || 0));
          // Nom connu, sinon « Vainq. X-Y » (les 2 équipes potentielles du match d'origine).
          const nm = (name: string, from: any) => name || (from ? `Vainq. ${from.home}-${from.away}` : 'À déterminer');
          const rows = (
            <>
              <div class={`bk-line${homeW ? ' w' : ''}${homeElim ? ' lost' : ''}${t.home ? '' : ' tbd'}`}>
                <span class="fl">{t.homeFlag || (t.home ? fl(t.home) : '')}</span><span class="nm">{nm(t.home, t.homeFrom)}</span>
                <span class="sc">{played ? t.actualHome : ''}{draw && t.penHome != null ? <i class="pk">({t.penHome})</i> : ''}</span>
              </div>
              <div class={`bk-line${awayW ? ' w' : ''}${awayElim ? ' lost' : ''}${t.away ? '' : ' tbd'}`}>
                <span class="fl">{t.awayFlag || (t.away ? fl(t.away) : '')}</span><span class="nm">{nm(t.away, t.awayFrom)}</span>
                <span class="sc">{played ? t.actualAway : ''}{draw && t.penAway != null ? <i class="pk">({t.penAway})</i> : ''}</span>
              </div>
            </>
          );
          if (t.upcoming) return <div class="bk-tie up" data-r={ri} data-s={si}>{rows}<span class="bk-foot up">{t.when || r.date || 'à venir'}</span></div>;
          return (
            <details class={`bk-tie${played ? '' : ' live'}`} data-r={ri} data-s={si}>
              <summary>{rows}<span class="bk-foot">{played ? (draw && penW ? `${t.date} · t.a.b.` : t.date) : <span class="bk-live">● en cours</span>}<span class="bk-caret">›</span></span></summary>
              <div class="bk-picks">
                {(t.picks || []).map((p: any) => {
                  const ok = p.points > 0, best = maxPts > 0 && p.points === maxPts;
                  return (
                    <div class={`bk-pick${best ? ' best' : ''}`}>
                      <span class="pn">{shortName(p.name)}</span>
                      <span class="pp">{p.predHome}<i>·</i>{p.predAway}</span>
                      <span class="pt">{played ? (ok ? '+' + p.points : '0') : '—'}</span>
                    </div>
                  );
                })}
              </div>
            </details>
          );
        })}
      </div>
    </div>
  ))}
</div>

<script>
  function drawLinks(wrap: HTMLElement) {
    const svg = wrap.querySelector('.bk-links') as SVGSVGElement | null;
    const path = svg?.querySelector('path') as SVGPathElement | null;
    if (!svg || !path) return;
    const map: Record<string, HTMLElement> = {};
    wrap.querySelectorAll<HTMLElement>('[data-r]').forEach((el) => { map[el.dataset.r + '-' + el.dataset.s] = el; });
    // On remet le SVG à 0 AVANT de mesurer : sinon, après avoir replié un match, sa taille
    // précédente (plus grande) gonfle scrollWidth/scrollHeight et laisse du scroll fantôme.
    svg.setAttribute('width', '0'); svg.setAttribute('height', '0');
    const W = wrap.scrollWidth, H = wrap.scrollHeight;
    svg.setAttribute('width', String(W)); svg.setAttribute('height', String(H));
    svg.setAttribute('viewBox', `0 0 ${W} ${H}`);
    const base = wrap.getBoundingClientRect();
    const c = (el: HTMLElement) => {
      const r = el.getBoundingClientRect();
      return { l: r.left - base.left + wrap.scrollLeft, r: r.right - base.left + wrap.scrollLeft, y: r.top - base.top + wrap.scrollTop + r.height / 2 };
    };
    let d = '';
    for (const key in map) {
      const [ri, si] = key.split('-').map(Number);
      if (ri === 0) continue;
      const a = map[(ri - 1) + '-' + (2 * si)], b = map[(ri - 1) + '-' + (2 * si + 1)], p = map[key];
      if (!a || !b) continue;
      const A = c(a), B = c(b), P = c(p), midX = (A.r + P.l) / 2;
      const vy1 = Math.min(A.y, B.y, P.y), vy2 = Math.max(A.y, B.y, P.y);
      d += `M${A.r} ${A.y} H${midX} M${B.r} ${B.y} H${midX} M${midX} ${vy1} V${vy2} M${midX} ${P.y} H${P.l} `;
    }
    path.setAttribute('d', d);
  }
  const wrap = document.querySelector('.bracket') as HTMLElement | null;
  if (wrap) {
    const draw = () => drawLinks(wrap);
    draw();
    requestAnimationFrame(draw);
    setTimeout(draw, 200);
    addEventListener('resize', draw);
    wrap.addEventListener('toggle', () => requestAnimationFrame(draw), true); // ouverture d'un match
    if ((document as any).fonts?.ready) (document as any).fonts.ready.then(draw);
  }
</script>

<style>
  .bracket { position: relative; display: flex; gap: 28px; overflow-x: auto; padding: 4px 2px 18px; -webkit-overflow-scrolling: touch; }
  .bk-links { position: absolute; top: 0; left: 0; pointer-events: none; z-index: 0; overflow: visible; }
  .bk-links path { fill: none; stroke: var(--gold-soft); stroke-width: 1.5; }
  .bk-round { min-width: 200px; flex: 0 0 auto; display: flex; flex-direction: column; position: relative; z-index: 1; }
  .bk-rk { position: sticky; top: 0; z-index: 2; font: 800 11px/1 var(--font); letter-spacing: .18em; text-transform: uppercase; color: var(--gold);
    margin: 0 0 10px; padding: 8px 0; background: var(--bg); border-bottom: 1px solid var(--line); }
  /* space-around → les tours suivants se centrent entre les paires (forme d'arbre) */
  .bk-ties { display: flex; flex-direction: column; justify-content: space-around; gap: 8px; flex: 1; }

  .bk-tie { background: var(--surface); border: 1px solid var(--line); border-radius: 12px; position: relative; }
  .bk-tie[open] { border-color: var(--gold-soft); }
  .bk-tie.live { border-color: rgba(227,52,47,.5); }
  .bk-tie.ph { border-style: dashed; opacity: .5; min-height: 60px; display: flex; align-items: center; justify-content: center; }
  .bk-ph { font-size: 11px; color: var(--text-dim); font-weight: 700; }
  .bk-tie.up { padding-bottom: 6px; }

  .bk-tie summary { list-style: none; cursor: pointer; }
  .bk-tie summary::-webkit-details-marker { display: none; }
  .bk-line { display: flex; align-items: center; gap: 7px; padding: 7px 10px; }
  .bk-line + .bk-line { border-top: 1px solid var(--line); }
  .bk-line .fl { font-size: 17px; line-height: 1; }
  .bk-line .nm { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-weight: 700; font-size: 13px; color: var(--text-dim); }
  .bk-line .sc { font-weight: 900; font-size: 15px; min-width: 12px; text-align: right; color: var(--text-dim); }
  /* le gagnant de CE match passe en doré ; le perdant reste gris */
  .bk-line.w { box-shadow: inset 3px 0 0 var(--gold); }
  .bk-line.w .nm { color: var(--gold); font-weight: 800; }
  .bk-line.w .sc { color: var(--gold); }
  /* équipe éliminée (a perdu un tour ultérieur, cf. bracket.mjs) : estompée pour ressortir des
     équipes encore en lice (dont le style .w plein ci-dessus ne change pas) */
  .bk-line.lost { opacity: .45; }
  .bk-line.lost .fl { filter: grayscale(70%); }
  /* cas particulier : équipe éliminée qui avait gagné CE match précis (ex. sortie au 8e après
     avoir remporté son 16e) → garde une touche dorée, mais estompée — pour voir qu'elle avait
     gagné sans la confondre avec les équipes encore en lice (doré plein) */
  .bk-line.lost.w { opacity: .6; box-shadow: inset 3px 0 0 color-mix(in srgb, var(--gold) 45%, var(--text-dim)); }
  .bk-line.lost.w .nm, .bk-line.lost.w .sc { color: color-mix(in srgb, var(--gold) 45%, var(--text-dim)); }
  .bk-line.lost.w .fl { filter: grayscale(40%); }
  /* équipe encore inconnue : « Vainq. X-Y » (les 2 potentielles) en italique atténué */
  .bk-line.tbd .nm { font-style: italic; font-weight: 700; font-size: 12px; opacity: .7; }
  /* score des tirs au but, entre parenthèses à côté du score */
  .bk-line .sc .pk { font-style: normal; font-size: 11px; font-weight: 800; margin-left: 3px; }

  .bk-foot { display: flex; align-items: center; justify-content: space-between; padding: 4px 10px 6px; font-size: 10px; color: var(--text-dim); font-weight: 700; }
  .bk-foot.up { justify-content: center; font-style: italic; opacity: .8; }
  .bk-live { color: var(--red); }
  .bk-caret { transition: transform .15s; }
  .bk-tie[open] .bk-caret { transform: rotate(90deg); }

  .bk-picks { border-top: 1px dashed var(--line); padding: 7px 10px 9px; display: flex; flex-direction: column; gap: 5px; }
  .bk-pick { position: relative; display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 8px; font-size: 12px; }
  .bk-pick .pn { color: var(--text-dim); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .bk-pick .pp { font-weight: 900; color: var(--gold); }
  .bk-pick .pp i { color: var(--text-dim); font-style: normal; margin: 0 2px; }
  .bk-pick .pt { font-weight: 800; font-size: 11px; min-width: 26px; text-align: right; color: #51e39a; }
  .bk-pick.best .pn { color: var(--text); font-weight: 800; }
</style>
