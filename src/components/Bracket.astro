---
// rounds: [{ name, ties: [{a,b,winner}] }]
const { rounds = [] } = Astro.props;
---
<div style="display:flex;gap:18px;overflow-x:auto;padding:6px 0">
  {rounds.map((r) => (
    <div style="min-width:150px;display:flex;flex-direction:column;justify-content:space-around;gap:10px">
      <p class="kicker">{r.name}</p>
      {r.ties.map((t) => (
        <div class="pill" style="padding:8px 10px;font-size:12px">
          <div style={t.winner === t.a ? 'font-weight:800;color:var(--gold)' : 'color:var(--text-dim)'}>{t.a}</div>
          <div style={t.winner === t.b ? 'font-weight:800;color:var(--gold)' : 'color:var(--text-dim)'}>{t.b}</div>
        </div>
      ))}
    </div>
  ))}
</div>
