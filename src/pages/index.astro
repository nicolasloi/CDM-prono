---
import Base from '../layouts/Base.astro';
import Sparkline from '../components/Sparkline.astro';
import MovementArrow from '../components/MovementArrow.astro';
import Trophy from '../components/Trophy.astro';
import RankChart from '../components/RankChart.astro';
import { getLatest, getTimeseries, getPretournament, keyOf } from '../data';
import { buildColorMap, shortName } from '../../scripts/lib/members.mjs';
import { buildRankByDay } from '../../scripts/lib/bump.mjs';
import { topMover } from '../../scripts/lib/form.mjs';
import { flagFor } from '../../scripts/lib/flags.mjs';
import predictionsData from '../../data/predictions.json';
import fixturesData from '../../data/fixtures.json';

const latest = getLatest();
const ts = getTimeseries();
const pret = getPretournament();
const members = latest.members;
const top3 = members.slice(0, 3);
const colorMap = buildColorMap(members.map((m) => keyOf(m)));
const bump = buildRankByDay(ts);
for (const k in bump.byId) bump.byId[k].name = shortName(bump.byId[k].name);
const mover = topMover(ts);
const moverDay = mover ? new Date(mover.day + 'T12:00:00Z').toLocaleDateString('fr-CH', { day: 'numeric', month: 'short', timeZone: 'UTC' }) : '';
const upcoming = (fixturesData.upcoming || []) as any[];
const nextMatch = upcoming[0] || null; // défaut au build ; le client choisit le bon « prochain »
const updated = new Date(latest.takenAt).toLocaleString('fr-CH', { dateStyle: 'long', timeStyle: 'short', timeZone: 'Europe/Zurich' });

// Enrichit les pronos avec les drapeaux (au build) pour le drawer.
const totalById: Record<string, number> = Object.fromEntries(members.map((m) => [m.id, m.totalPoints]));
const preds: Record<string, any> = {};
for (const [id, p] of Object.entries<any>(predictionsData.byId)) {
  const pretAnswers = pret.byId[id];
  preds[id] = {
    name: shortName(p.name),
    total: totalById[id] ?? null, // total officiel (= classement), inclut les points bonus hors match
    matches: p.matches.map((m: any) => ({ ...m, homeFlag: flagFor(m.home), awayFlag: flagFor(m.away) })),
    // Drapeau du pays pronostiqué champion (uniquement sur la fiche du joueur, pas dans le classement).
    pretournament: pretAnswers ? { ...pretAnswers, championFlag: pretAnswers.champion ? flagFor(pretAnswers.champion) : null } : null,
  };
}
const podiumOrder = [1, 0, 2];
const medal = ['var(--gold)', '#cdd2dc', '#cd7f4d'];
const pedestalH: Record<number, number> = { 0: 150, 1: 108, 2: 84 };
---
<Base title="Classement">
  <!-- HERO -->
  <section class="hero">
    <div class="streaks" aria-hidden="true">
      <svg viewBox="0 0 1200 240" preserveAspectRatio="none">
        <path d="M-40 150 C260 70 520 200 1240 110" stroke="var(--red)" stroke-width="9" fill="none" stroke-linecap="round"/>
        <path d="M-40 178 C300 110 560 220 1240 150" stroke="var(--green)" stroke-width="9" fill="none" stroke-linecap="round"/>
        <path d="M-40 206 C240 150 600 250 1240 188" stroke="var(--blue)" stroke-width="9" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="num26" aria-hidden="true">26</div>
    <p class="kicker">★ Marvelous Digital · Coupe du Monde 2026</p>
    <h1 class="h1">Le <em>Classement</em></h1>
    <p class="dim updated">Dernière mise à jour : {updated}</p>
  </section>

  <!-- BANDEAU LIVE : prochain match + en forme -->
  {(nextMatch || mover) && (
    <section class="strip">
      {nextMatch && (
        <div class="strip-card next" id="next-card">
          <span class="strip-k"><span class="tick">⏱</span> Prochain match</span>
          <span class="strip-main" id="next-main">{nextMatch.homeFlag} {nextMatch.home} <i>–</i> {nextMatch.away} {nextMatch.awayFlag}</span>
          <span class="strip-val" id="next-cd">—</span>
        </div>
      )}
      {mover && (
        <div class="strip-card form">
          <span class="strip-k">🔥 En forme</span>
          <span class="strip-main">{mover.names.map(shortName).join(', ')}</span>
          <span class="strip-val">+{mover.gain} <small>pts · {moverDay}</small></span>
        </div>
      )}
    </section>
  )}

  <!-- PODIUM -->
  <section class="podium">
    {podiumOrder.filter((i) => top3[i]).map((i) => (
      <button class="ped" data-id={top3[i].id} style={`--h:${pedestalH[i]}px;--medal:${medal[i]}`}>
        {i === 0 && <div class="ped-trophy"><Trophy size={40} /></div>}
        <div class="ped-name">{shortName(top3[i].name)}</div>
        <div class="ped-pts">{top3[i].totalPoints}<span>pts</span></div>
        <div class="ped-base">
          <span class="ped-rank">{top3[i].rank}</span>
        </div>
      </button>
    ))}
  </section>

  <!-- C'EST MOI -->
  <div class="me-bar">
    <button id="me-btn" class="me-btn" aria-haspopup="true"><span class="me-ico">👤</span><span id="me-label">Tu joues ? Marque-toi</span><span class="me-car">▾</span></button>
    <div id="me-pop" class="me-pop" hidden>
      <p class="me-pop-h">Qui es-tu&nbsp;?</p>
      <div class="me-grid">
        {members.map((m) => (
          <button class="me-opt" data-id={m.id} data-name={shortName(m.name)}><span class="cdot" style={`background:${colorMap[keyOf(m)]}`}></span>{shortName(m.name)}</button>
        ))}
      </div>
      <button class="me-opt me-clear" data-id="" data-name="">Effacer</button>
    </div>
  </div>

  <!-- LISTE -->
  <section class="board">
    {members.map((m, idx) => (
      <button class={`lbrow${idx === 0 ? ' leader' : ''}`} data-id={m.id} style={`--accent:${colorMap[keyOf(m)]};--i:${idx}`}>
        <span class="rk">{m.rank}</span>
        <span class="dot"></span>
        <span class="who">
          <span class="nm">{shortName(m.name)}</span>
          <span class="see">Voir ses pronos →</span>
        </span>
        <span class="spark"><Sparkline points={ts[keyOf(m)] || []} w={84} h={26} color={colorMap[keyOf(m)]} /></span>
        <span class="mv"><MovementArrow delta={m.rankDelta} /></span>
        <span class="pts">{m.totalPoints}</span>
      </button>
    ))}
  </section>

  <!-- ÉVOLUTION -->
  {bump.days.length > 1 && (
    <section class="evo">
      <p class="kicker">★ Le fil du classement</p>
      <h2 class="evo-h">L'<em>évolution</em> des places</h2>
      <RankChart data={bump} colorMap={colorMap} />
    </section>
  )}

  <p class="dim foot-note">Clique sur un joueur pour voir tous ses pronostics, match par match. Points et classement issus du jeu RTS, rafraîchis automatiquement plusieurs fois par jour.</p>

  <!-- DRAWER -->
  <div id="backdrop"></div>
  <aside id="drawer" aria-hidden="true">
    <button id="drawer-close" aria-label="Fermer">✕</button>
    <div id="drawer-body"></div>
  </aside>

  <script is:inline define:vars={{ preds, pretQuestions: pret.questions, pretActuals: pret.actuals }}>
    window.__PREDS = preds;
    window.__PRET_Q = pretQuestions;
    window.__PRET_ACTUALS = pretActuals;
  </script>
  <script>
    const PREDS = (window as any).__PREDS || {};
    const PRET_Q = (window as any).__PRET_Q || [];
    const PRET_ACTUALS = (window as any).__PRET_ACTUALS || {};
    const drawer = document.getElementById('drawer')!;
    const backdrop = document.getElementById('backdrop')!;
    const body = document.getElementById('drawer-body')!;
    const esc = (s: any) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

    function matchRow(m: any) {
      const hasScore = m.actualHome != null && m.actualAway != null;
      const ok = m.points > 0;
      const exact = hasScore && m.predHome === m.actualHome && m.predAway === m.actualAway;
      return `
        <div class="m">
          <div class="m-top">
            <span class="m-date">${esc(m.date)}</span>
            <span class="m-pts ${ok ? 'ok' : 'no'}">${hasScore ? (ok ? '+' + m.points : '0') + ' pts' + (exact ? ' · exact' : '') : 'en cours'}</span>
          </div>
          <div class="m-mid">
            <span class="m-team"><span class="fl">${esc(m.homeFlag)}</span>${esc(m.home)}</span>
            <span class="m-pred">${m.predHome}<i>–</i>${m.predAway}</span>
            <span class="m-team r">${esc(m.away)}<span class="fl">${esc(m.awayFlag)}</span></span>
          </div>
          <div class="m-bot"><span class="m-real">${hasScore ? `Résultat <b>${m.actualHome}–${m.actualAway}</b>` : '<b>En cours</b>'}</span><span class="m-stad">${esc(m.stadium)}</span></div>
        </div>`;
    }

    // Réponses "actuelles" affichables (dérivées des résultats déjà connus) par clé de question.
    // buteurButs volontairement absent : pas de stat buteur individuel scrapée, donc pas de valeur honnête.
    function actualFor(key: string) {
      if (key === 'matchsNuls' && PRET_ACTUALS.matchsNuls != null) return String(PRET_ACTUALS.matchsNuls);
      if (key === 'suisseButs' && PRET_ACTUALS.suisseButs != null) return String(PRET_ACTUALS.suisseButs);
      if (key === 'suisseParcours' && PRET_ACTUALS.suisseParcours) return PRET_ACTUALS.suisseParcours;
      return null;
    }
    function pretBlock(p: any) {
      const answers = p.pretournament;
      if (!answers || !PRET_Q.length) return '';
      const rows = PRET_Q.map((q: any) => {
        const val = answers[q.key];
        if (val == null) return '';
        const actual = actualFor(q.key);
        const lost = !!answers.lost?.[q.key]; // déjà mathématiquement impossible → grisé
        const flag = q.key === 'champion' && answers.championFlag ? answers.championFlag + ' ' : '';
        return `
          <div class="pq${lost ? ' lost' : ''}">
            <span class="pq-q">${esc(q.question)}</span>
            <span class="pq-a">${flag}${esc(val)}${lost ? ' <i class="pq-x">✗ perdu</i>' : ''}</span>
            ${actual && !lost ? `<span class="pq-actual">actuel : <b>${esc(actual)}</b></span>` : ''}
          </div>`;
      }).join('');
      if (!rows) return '';
      return `
        <div class="d-pret">
          <p class="d-pret-h">🎲 Pronostics d'avant-tournoi</p>
          ${rows}
        </div>`;
    }

    function open(id: string) {
      const p = PREDS[id];
      if (!p) return;
      const sg = (a: number, b: number) => Math.sign(a - b);
      const done = p.matches.filter((m: any) => m.actualHome != null && m.actualAway != null);
      const tot = done.length;
      const isExact = (m: any) => m.predHome === m.actualHome && m.predAway === m.actualAway;
      const sameDiff = (m: any) => (m.predHome - m.predAway) === (m.actualHome - m.actualAway);
      const sameOut = (m: any) => sg(m.predHome, m.predAway) === sg(m.actualHome, m.actualAway);
      const tiers = [
        { label: '🎯 Score exact', color: 'var(--gold)', n: done.filter(isExact).length },
        { label: '📐 Vainqueur + écart', color: '#51e39a', n: done.filter((m: any) => !isExact(m) && sameDiff(m)).length },
        { label: '✅ Bon vainqueur', color: '#2dd4ff', n: done.filter((m: any) => sameOut(m) && !sameDiff(m)).length },
        { label: '❌ Raté', color: 'var(--text-dim)', n: done.filter((m: any) => !sameOut(m)).length },
      ];
      const hit = done.filter(sameOut).length; // « réussi » = au moins le bon vainqueur (cohérent avec la tranche « raté »)
      const acc = tot ? Math.round((hit / tot) * 100) : 0;
      const pct = (n: number) => (tot ? Math.round((n / tot) * 100) : 0);
      const breakdown = tot ? `<div class="d-break">` + tiers.map((t) => `
        <div class="dbk">
          <span class="dbk-l">${t.label}</span>
          <span class="dbk-bar"><span style="width:${pct(t.n)}%;background:${t.color}"></span></span>
          <span class="dbk-v">${pct(t.n)}% <small>· ${t.n}</small></span>
        </div>`).join('') + `</div>` : '';
      body.innerHTML = `
        <div class="d-head">
          <p class="kicker">Parcours</p>
          <h2 class="d-name">${esc(p.name)}</h2>
          <div class="d-stats">
            ${p.total != null ? `<span><b>${p.total}</b> pts</span>` : ''}
            <span><b>${p.matches.length}</b> pronos</span>
            <span><b>${acc}%</b> réussis</span>
          </div>
          ${breakdown}
        </div>`;
      body.innerHTML += pretBlock(p);
      body.innerHTML += `
        ${p.matches.length ? `<div class="d-list">${p.matches.map(matchRow).join('')}</div>` : '<p class="dim" style="padding:18px">Aucun prono révélé pour l’instant.</p>'}`;
      drawer.classList.add('open');
      backdrop.classList.add('show');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }
    function close() {
      drawer.classList.remove('open');
      backdrop.classList.remove('show');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    document.querySelectorAll('.lbrow[data-id], .ped[data-id]').forEach((el) => {
      el.addEventListener('click', () => { const id = el.getAttribute('data-id'); if (id) open(id); });
    });
    backdrop.addEventListener('click', close);
    document.getElementById('drawer-close')!.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
  </script>

  <script>
    // « C'est moi » : marque ton nom (mémorisé sur ton appareil) → ligne + courbe mises en avant.
    const MEKEY = 'cdm-me';
    const meBtn = document.getElementById('me-btn');
    const mePop = document.getElementById('me-pop');
    const meLabel = document.getElementById('me-label');
    function applyMe(id, name) {
      document.querySelectorAll('.lbrow.me').forEach((r) => { r.classList.remove('me'); r.querySelector('.metag')?.remove(); });
      document.querySelectorAll('.ln.me').forEach((l) => l.classList.remove('me'));
      if (id) {
        const row = document.querySelector('.lbrow[data-id="' + id + '"]');
        if (row) {
          row.classList.add('me');
          const nm = row.querySelector('.nm');
          if (nm && !nm.querySelector('.metag')) { const t = document.createElement('span'); t.className = 'metag'; t.textContent = 'TOI'; nm.appendChild(t); }
        }
        const ln = document.querySelector('.ln[data-key="' + id + '"]');
        if (ln) ln.classList.add('me');
        if (meLabel) meLabel.textContent = 'Toi : ' + (name || '') + ' · changer';
      } else if (meLabel) {
        meLabel.textContent = 'Tu joues ? Marque-toi';
      }
    }
    if (meBtn && mePop && meLabel) {
      const saved = localStorage.getItem(MEKEY);
      if (saved) { const o = mePop.querySelector('.me-opt[data-id="' + saved + '"]'); applyMe(saved, o && o.dataset.name); }
      meBtn.addEventListener('click', (e) => { e.stopPropagation(); mePop.hidden = !mePop.hidden; });
      mePop.querySelectorAll('.me-opt').forEach((o) => o.addEventListener('click', () => {
        const id = o.dataset.id;
        if (id) localStorage.setItem(MEKEY, id); else localStorage.removeItem(MEKEY);
        applyMe(id, o.dataset.name);
        mePop.hidden = true;
      }));
      document.addEventListener('click', (e) => { if (!e.target.closest('.me-bar')) mePop.hidden = true; });
    }
  </script>

  <script is:inline define:vars={{ upcoming }}>
    window.__UP = upcoming;
  </script>
  <script>
    // Prochain match + compte à rebours (recalculé côté client → toujours juste).
    const UP = window.__UP || [];
    const nCard = document.getElementById('next-card');
    const nMain = document.getElementById('next-main');
    const nCd = document.getElementById('next-cd');
    function fmtCd(ms) {
      if (ms <= 0) return 'maintenant';
      const s = Math.floor(ms / 1000), d = Math.floor(s / 86400), h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
      if (d > 0) return 'dans ' + d + 'j ' + h + 'h';
      if (h > 0) return 'dans ' + h + 'h ' + String(m).padStart(2, '0') + 'm';
      return 'dans ' + m + 'm ' + String(sec).padStart(2, '0') + 's';
    }
    function nEsc(s) { return String(s == null ? '' : s); }
    function tickNext() {
      if (!nCard) return;
      const now = Date.now();
      const next = UP.find((f) => Date.parse(f.kickoff) > now);
      if (!next) { nCard.style.display = 'none'; return; }
      nCard.style.display = '';
      if (nMain) nMain.innerHTML = nEsc(next.homeFlag) + ' ' + nEsc(next.home) + ' <i>–</i> ' + nEsc(next.away) + ' ' + nEsc(next.awayFlag);
      if (nCd) nCd.textContent = fmtCd(Date.parse(next.kickoff) - now);
    }
    if (nCard) { tickNext(); setInterval(tickNext, 1000); }
  </script>

  <style is:global>
    main { padding-top: 8px !important; }

    /* BANDEAU LIVE */
    .strip { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 14px 0 6px; }
    @media (max-width: 560px) { .strip { grid-template-columns: 1fr; } }
    .strip-card { display: flex; flex-direction: column; gap: 4px; background: var(--surface); border: 1px solid var(--line); border-radius: 16px; padding: 13px 16px; min-width: 0; }
    .strip-card.next { border-color: var(--gold-soft); }
    .strip-k { font: 800 10px/1 var(--font); letter-spacing: .16em; text-transform: uppercase; color: var(--gold); display: flex; align-items: center; gap: 6px; }
    .strip-card.form .strip-k { color: #ff7a3d; }
    .strip .tick { animation: tickp 2s ease-in-out infinite; }
    @keyframes tickp { 0%,100% { opacity: 1; } 50% { opacity: .35; } }
    .strip-main { font-weight: 800; font-size: clamp(15px, 2.2vw, 18px); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .strip-main i { color: var(--text-dim); font-style: normal; margin: 0 5px; }
    .strip-val { font-weight: 800; font-size: 13px; color: var(--text-dim); }
    .strip-card.next .strip-val { color: var(--gold); }
    .strip-val small { color: var(--text-dim); font-weight: 600; }

    /* HERO */
    .hero { position: relative; padding: 18px 0 8px; }
    .hero .streaks { position: absolute; inset: -10px -20px auto; height: 230px; opacity: .95; z-index: 0; }
    .hero .streaks svg { width: 100%; height: 100%; }
    .hero .num26 { position: absolute; right: -8px; top: -34px; font: 900 italic clamp(120px, 22vw, 240px)/1 var(--font); color: transparent; -webkit-text-stroke: 2px var(--gold-soft); z-index: 0; pointer-events: none; }
    .hero .kicker, .hero .h1, .hero .updated { position: relative; z-index: 1; }
    .hero .updated { font-size: 13px; margin-top: 10px; z-index: 3; display: inline-block; background: color-mix(in srgb, var(--bg) 80%, transparent); padding: 4px 12px; border-radius: 18px; backdrop-filter: blur(2px); }
    @media (prefers-reduced-motion: no-preference) {
      .hero .streaks { animation: drift 9s ease-in-out infinite alternate; }
      .hero .num26 { animation: float26 7s ease-in-out infinite alternate; }
    }
    @keyframes float26 { from { transform: translateY(0); } to { transform: translateY(-10px); } }

    /* PODIUM */
    .podium { display: flex; align-items: flex-end; justify-content: center; gap: 14px; margin: 26px 0 30px; }
    .ped { flex: 1; max-width: 220px; background: none; border: 0; cursor: pointer; color: inherit; font-family: inherit; text-align: center; padding: 0; transition: transform .18s ease; }
    .ped:hover { transform: translateY(-6px); }
    .ped-trophy { margin-bottom: 6px; filter: drop-shadow(0 6px 16px rgba(232,198,106,.4)); }
    .ped-name { font-weight: 700; font-size: clamp(13px, 1.6vw, 16px); }
    .ped-pts { font-weight: 900; color: var(--gold); font-size: clamp(22px, 3.4vw, 34px); line-height: 1.1; }
    .ped-pts span { font-size: 12px; color: var(--text-dim); font-weight: 700; margin-left: 3px; }
    .ped-base { height: var(--h); margin-top: 8px; border-radius: 16px 16px 0 0; position: relative;
      background: linear-gradient(180deg, color-mix(in srgb, var(--medal) 22%, var(--bg-soft)), var(--bg-soft));
      border: 1px solid var(--line); border-top: 3px solid var(--medal);
      box-shadow: inset 0 18px 40px -28px var(--medal); display: flex; align-items: flex-start; justify-content: center; }
    .ped:first-child .ped-base { box-shadow: inset 0 18px 40px -22px var(--medal), 0 0 50px -16px var(--gold-soft); }
    .ped-rank { font-weight: 900; font-size: 26px; color: var(--medal); margin-top: 10px; opacity: .9; }

    /* BOARD */
    .board { display: flex; flex-direction: column; gap: 8px; }
    .lbrow { display: grid; grid-template-columns: 46px 10px 1fr auto auto 76px; align-items: center; gap: 14px;
      width: 100%; text-align: left; cursor: pointer; color: inherit; font-family: inherit;
      background: var(--surface); border: 1px solid transparent; border-radius: 18px; padding: 16px 20px;
      transition: transform .14s ease, border-color .14s ease, background .14s ease; }
    @media (prefers-reduced-motion: no-preference) {
      .lbrow { opacity: 0; transform: translateY(8px); animation: rise .5s cubic-bezier(.2,.7,.2,1) forwards; animation-delay: calc(var(--i) * 55ms); }
    }
    @keyframes rise { to { opacity: 1; transform: none; } }
    .lbrow:hover { transform: translateY(-2px); border-color: var(--gold-soft); background: var(--surface-hi); }
    .lbrow .rk { font-weight: 900; font-size: clamp(22px, 3vw, 30px); color: var(--text-dim); text-align: center; }
    .lbrow .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); }
    .lbrow .who { display: flex; flex-direction: row; align-items: center; gap: 10px; min-width: 0; }
    .lbrow .nm { font-weight: 700; font-size: clamp(16px, 2.1vw, 21px); display: flex; align-items: center; gap: 8px; }
    .lbrow .nm .adm { font-style: normal; font-size: 9px; letter-spacing: .12em; text-transform: uppercase; color: var(--bg); background: var(--gold); padding: 2px 6px; border-radius: 20px; font-weight: 800; }
    .lbrow .see { font-size: 12px; color: var(--text-dim); opacity: 0; transform: translateX(-4px); transition: .15s; white-space: nowrap; }
    .lbrow:hover .see { opacity: 1; transform: none; color: var(--gold); }
    .lbrow .spark { display: flex; }
    .lbrow .pts { font-weight: 900; font-size: clamp(20px, 2.6vw, 26px); text-align: right; }
    .lbrow.leader { border-color: var(--gold-soft); background: linear-gradient(100deg, var(--gold-soft), transparent 60%); }
    .lbrow.leader .rk { color: var(--gold); }
    @media (max-width: 620px) {
