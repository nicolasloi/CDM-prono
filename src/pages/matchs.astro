---
import Base from '../layouts/Base.astro';
import matchesData from '../../data/matches.json';

const matches = (matchesData.matches as any[]).slice(0, 6);
---
<Base title="Matchs">
  <section class="hero2">
    <p class="kicker">★ Qui a misé quoi</p>
    <h1 class="h1">Les <em>Matchs</em></h1>
    <p class="dim" style="font-size:13px;margin-top:6px">Les 6 derniers matchs et les pronos de chaque membre. Dès le coup d'envoi, les pronos s'affichent et le match passe « en cours ».</p>
  </section>

  <section class="matches">
    {matches.map((m) => {
      const exactOf = (p: any) => p.predHome === m.actualHome && p.predAway === m.actualAway;
      return (
        <article class="match" data-kickoff={m.kickoff}>
          <div class="mhead">
            <div class="team"><span class="fl">{m.homeFlag}</span><span class="tn">{m.home}</span></div>
            <div class="score">
              <b>{m.actualHome}</b><i>:</i><b>{m.actualAway}</b>
              <span class="status">Terminé</span>
            </div>
            <div class="team r"><span class="tn">{m.away}</span><span class="fl">{m.awayFlag}</span></div>
          </div>
          <div class="msub">{m.date} · {m.stadium}</div>
          <div class="picks">
            {m.picks.map((p: any) => {
              const ok = p.points > 0;
              return (
                <div class={`pick${exactOf(p) ? ' exact' : ''}`}>
                  <span class="pn">{p.name}</span>
                  <span class="pp">{p.predHome}<i>–</i>{p.predAway}</span>
                  <span class={`ppt ${ok ? 'ok' : 'no'}`}>{ok ? '+' + p.points : '0'}{exactOf(p) ? ' ★' : ''}</span>
                </div>
              );
            })}
          </div>
        </article>
      );
    })}
    {matches.length === 0 && <p class="dim">Les matchs s'afficheront ici dès les premiers coups d'envoi.</p>}
  </section>

  <script>
    const DUR = 2.25 * 3600 * 1000; // ~2h15
    const now = Date.now();
    document.querySelectorAll('.match[data-kickoff]').forEach((el) => {
      const ko = Date.parse(el.dataset.kickoff || '');
      const st = el.querySelector('.status');
      if (!st || Number.isNaN(ko)) return;
      if (now >= ko && now <= ko + DUR) { el.classList.add('live'); st.textContent = 'EN COURS'; }
      else if (now < ko) { el.classList.add('soon'); st.textContent = 'À venir'; }
    });
  </script>

  <style is:global>
    .hero2 { padding: 18px 0 14px; }
    .matches { display: flex; flex-direction: column; gap: 14px; }
    .match { background: var(--surface); border: 1px solid var(--line); border-radius: 18px; padding: 16px 18px; }
    .match.live { border-color: rgba(227,52,47,.5); box-shadow: 0 0 40px -18px var(--red); }
    .mhead { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 12px; }
    .team { display: flex; align-items: center; gap: 9px; font-weight: 800; font-size: clamp(15px, 2.2vw, 19px); }
    .team.r { justify-content: flex-end; text-align: right; }
    .team .fl { font-size: 22px; }
    .score { text-align: center; position: relative; }
    .score b { font-weight: 900; font-size: clamp(22px, 4vw, 32px); }
    .score i { color: var(--text-dim); font-style: normal; margin: 0 7px; }
    .score .status { display: block; font-size: 9px; font-weight: 800; letter-spacing: .14em; text-transform: uppercase; color: var(--text-dim); margin-top: 2px; }
    .match.live .status { color: var(--red); }
    .match.live .status::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: var(--red); margin-right: 5px; vertical-align: middle; animation: pulse 1.1s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .25; } }
    .msub { text-align: center; font-size: 11px; color: var(--text-dim); margin: 8px 0 14px; }
    .picks { display: grid; grid-template-columns: repeat(auto-fill, minmax(172px, 1fr)); gap: 8px; }
    .pick { display: flex; align-items: center; gap: 8px; background: var(--bg); border: 1px solid var(--line); border-radius: 12px; padding: 8px 11px; }
    .pick.exact { border-color: var(--gold-soft); }
    .pick .pn { flex: 1; font-weight: 600; font-size: 13px; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .pick .pp { font-weight: 900; color: var(--gold); font-size: 14px; }
    .pick .pp i { color: var(--text-dim); font-style: normal; margin: 0 1px; }
    .pick .ppt { font-size: 11px; font-weight: 800; padding: 2px 7px; border-radius: 16px; }
    .pick .ppt.ok { background: rgba(0,168,90,.18); color: #51e39a; }
    .pick .ppt.no { background: var(--surface-hi); color: var(--text-dim); }
  </style>
</Base>
