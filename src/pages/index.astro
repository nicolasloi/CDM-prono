---
import Base from '../layouts/Base.astro';
import Streaks from '../components/Streaks.astro';
import Podium from '../components/Podium.astro';
import LeaderboardRow from '../components/LeaderboardRow.astro';
import { getLatest, getTimeseries, keyOf } from '../data';

const latest = getLatest();
const ts = getTimeseries();
const top3 = latest.members.slice(0, 3);
const rest = latest.members;
const updated = new Date(latest.takenAt).toLocaleString('fr-CH', { dateStyle: 'medium', timeStyle: 'short' });
const hasExperts = latest.experts && latest.experts.length > 0;
const expertsBest = hasExperts ? Math.max(...latest.experts) : null;
---
<Base title="Classement">
  <section style="position:relative">
    <div style="position:relative;height:120px">
      <Streaks height={120} />
      <div style="position:absolute;right:0;top:-6px;font:900 italic 96px/1 var(--font);color:transparent;-webkit-text-stroke:2px var(--gold-soft)">26</div>
      <div style="position:relative;z-index:1;padding-top:18px">
        <p class="kicker">★ Marvelous Digital</p>
        <h1 class="h1">Le <em>Classement</em></h1>
      </div>
    </div>
    <p class="dim" style="font-size:12px;margin:0 0 14px">
      Dernière mise à jour : {updated} · <a href="#methode" style="color:var(--gold)">comment ça marche</a>
    </p>

    <Podium top={top3} />

    {rest.map((m, i) => (
      <LeaderboardRow m={m} index={i} spark={ts[keyOf(m)] || []} />
    ))}

    {hasExperts && (
      <div class="pill" style="display:flex;align-items:center;gap:11px;padding:11px 16px;margin:14px 0 6px;border:1px dashed var(--line);background:transparent">
        <span style="width:20px;text-align:center">🤖</span>
        <span style="flex:1;font-weight:600" class="dim">Meilleur expert RTS</span>
        <span style="font-weight:800">{expertsBest}</span>
      </div>
    )}

    <button id="me-btn" class="pill" style="margin-top:16px;padding:8px 14px;border:1px solid var(--gold-soft);background:transparent;color:var(--gold);font-weight:700;cursor:pointer;border-radius:30px;font-size:13px">
      C'est moi → choisir mon nom
    </button>

    <p id="methode" class="dim" style="font-size:12px;margin-top:24px">
      Les points proviennent du jeu de pronostics RTS et sont rafraîchis automatiquement plusieurs fois par jour.
    </p>
  </section>

  <script>
    const KEY = 'marvelous-me';
    const btn = document.getElementById('me-btn');
    function highlight(name) {
      document.querySelectorAll('.row').forEach((r) => {
        if (r.dataset.key === name) {
          r.style.background = 'var(--gold-soft)';
          r.style.boxShadow = 'inset 0 0 0 1px var(--gold-soft)';
        }
      });
    }
    const saved = localStorage.getItem(KEY);
    if (saved) highlight(saved);
    btn?.addEventListener('click', () => {
      const names = [...document.querySelectorAll('.row')].map((r) => r.dataset.key);
      const choice = prompt('Ton nom dans le classement :\n' + names.join('\n'));
      if (choice && names.includes(choice)) { localStorage.setItem(KEY, choice); highlight(choice); }
    });
  </script>
</Base>
