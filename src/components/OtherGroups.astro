---
const { groups = [] } = Astro.props;
---
<div class="pill" style="padding:16px">
  <p class="kicker" style="margin-bottom:10px">Marvelous vs les autres groupes</p>
  {groups.map((g) => (
    <div style="display:flex;gap:10px;padding:6px 0;border-bottom:1px solid var(--line)">
      <span style="color:var(--gold);font-weight:800;width:28px">#{g.rank}</span>
      <span style="flex:1">{g.name}</span>
      <span style="font-weight:800">{g.points}</span>
    </div>
  ))}
</div>
