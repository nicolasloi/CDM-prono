---
import Base from '../layouts/Base.astro';
import Bracket from '../components/Bracket.astro';
import matchesData from '../../data/matches.json';
import { buildBracket } from '../../scripts/lib/bracket.mjs';

const rounds = buildBracket(matchesData.matches as any[]);
---
<Base title="Tableau">
  <section class="hero2">
    <p class="kicker">★ Phases finales</p>
    <h1 class="h1">Le <em>Tableau</em></h1>
    <p class="dim lede">Le parcours de la Coupe du Monde, des 16es à la finale. Touche un match pour voir le prono de chaque joueur.</p>
  </section>

  {rounds.length === 0
    ? <p class="dim empty">Les phases finales s'afficheront ici dès les 16es de finale (28 juin). Reviens bientôt !</p>
    : <Bracket rounds={rounds} />}

  <style>
    .hero2 { padding: 18px 0 14px; }
    .lede { font-size: 13px; margin-top: 6px; max-width: 60ch; }
    .empty { padding: 30px 0; }
  </style>
</Base>
