---
import Base from '../layouts/Base.astro';
import MatchCard from '../components/MatchCard.astro';
import { getCollection } from 'astro:content';
import { ghostTotal } from '../../scripts/lib/scoring.mjs';
import { getLatest } from '../data';
import Bracket from '../components/Bracket.astro';
const bracket = []; // rempli plus tard (phases finales)

const entries = (await getCollection('pronos')).sort((a, b) => a.data.order - b.data.order);
const allMatches = entries.flatMap((e) => e.data.matches.map((m) => ({ ...m, stage: e.data.stage })));
const ghost = ghostTotal(allMatches.map((m) => ({
  result: { home: m.predHome, away: m.predAway },
  actual: m.actualHome !== null ? { home: m.actualHome, away: m.actualAway } : null,
  stage: m.stage,
})));
const human = getLatest().members.map((m) => m.totalPoints);
const ghostRank = 1 + human.filter((p) => p > ghost).length;
---
<Base title="Pronos IA">
  <p class="kicker">🤖 L'Oracle — pronostics générés par l'IA</p>
  <h1 class="h1">Les Pronos de <em>l'IA</em></h1>
  <p class="dim" style="font-size:13px">Ce ne sont <strong>pas</strong> les pronos des membres : ce sont les analyses de l'IA. Si l'IA jouait, elle serait <strong style="color:var(--gold)">{ghostRank}e</strong> avec <strong>{ghost}</strong> pts.</p>

  <p class="pill" style="font-size:12px;padding:10px 14px;margin-top:12px;color:var(--text-dim);border:1px solid var(--line);background:transparent">
    ⚖️ <strong>Transparence</strong> — les pronos des 2 matchs d'ouverture (11 juin) ont été ajoutés <em>après</em> le coup d'envoi, le site ayant été lancé en cours de tournoi. Ils ont été faits de bonne foi (logique d'avant-match : favoris, classement, forme), sans recopier les scores. Tous les pronos suivants sont publiés <strong>avant</strong> les matchs.
  </p>

  {entries.map((e) => (
    <section style="margin-top:22px">
      <p class="kicker">{e.data.round}</p>
      {e.data.matches.map((m) => <MatchCard m={m} stage={e.data.stage} />)}
    </section>
  ))}

  {bracket.length > 0 && (
    <section style="margin-top:26px">
      <p class="kicker">Bracket prédictif</p>
      <Bracket rounds={bracket} />
    </section>
  )}
</Base>
