---
import Base from '../layouts/Base.astro';
import Trophy from '../components/Trophy.astro';
import { getLatest, keyOf } from '../data';
import { buildColorMap, shortName } from '../../scripts/lib/members.mjs';

const latest = getLatest();
const members = latest.members;
const colorMap = buildColorMap(members.map((m) => keyOf(m)));
const top3 = members.slice(0, 3);
const rest = members.slice(3);
const updated = new Date(latest.takenAt).toLocaleDateString('fr-CH', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'Europe/Zurich' });
const podiumOrder = [1, 0, 2];
const medal = ['var(--gold)', '#cdd2dc', '#cd7f4d'];
const pedestalH: Record<number, number> = { 0: 190, 1: 140, 2: 110 };
---
<Base title="Classement à imprimer">
  <section class="no-print bar">
    <p class="dim">Un joli souvenir du classement à garder une fois la Coupe du monde terminée. Ouvre la boîte d'impression, choisis « Enregistrer en PDF » comme imprimante, et coche « graphismes d'arrière-plan » pour garder les couleurs.</p>
    <button id="print-btn" class="print-btn">🖨️ Imprimer / Enregistrer en PDF</button>
  </section>

  <div class="poster" id="poster">
    <div class="streaks" aria-hidden="true">
      <svg viewBox="0 0 1200 240" preserveAspectRatio="none">
        <path d="M-40 150 C260 70 520 200 1240 110" stroke="var(--red)" stroke-width="9" fill="none" stroke-linecap="round"/>
        <path d="M-40 178 C300 110 560 220 1240 150" stroke="var(--green)" stroke-width="9" fill="none" stroke-linecap="round"/>
        <path d="M-40 206 C240 150 600 250 1240 188" stroke="var(--blue)" stroke-width="9" fill="none" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="num26" aria-hidden="true">26</div>

    <div class="poster-head">
      <p class="kicker">★ Marvelous Digital · Coupe du monde 2026</p>
      <h1 class="poster-h1">Le <em>Classement</em></h1>
      <p class="poster-sub">Souvenir arrêté au {updated}</p>
    </div>

    <section class="poster-podium">
      {podiumOrder.filter((i) => top3[i]).map((i) => (
        <div class="pp" style={`--h:${pedestalH[i]}px;--medal:${medal[i]}`}>
          {i === 0 && <div class="pp-trophy"><Trophy size={46} /></div>}
          <div class="pp-name">{shortName(top3[i].name)}</div>
          <div class="pp-pts">{top3[i].totalPoints}<span>pts</span></div>
          <div class="pp-base"><span class="pp-rank">{top3[i].rank}</span></div>
        </div>
      ))}
    </section>

    <ol class="poster-list">
      {rest.map((m) => (
        <li class="pr" style={`--accent:${colorMap[keyOf(m)]}`}>
          <span class="pr-rk">{m.rank}</span>
          <span class="pr-dot"></span>
          <span class="pr-nm">{shortName(m.name)}</span>
          <span class="pr-pt">{m.totalPoints}<small> pts</small></span>
        </li>
      ))}
    </ol>
  </div>
</Base>

<script>
  document.getElementById('print-btn')?.addEventListener('click', () => window.print());
</script>

<style>
  .bar { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px; margin-bottom: 22px; }
  .bar p { max-width: 50ch; font-size: 13px; margin: 0; }
  .print-btn { flex: 0 0 auto; border: none; border-radius: 999px; padding: 12px 22px; font: 800 14px var(--font); background: var(--gold); color: #17140a; cursor: pointer; }
  .print-btn:hover { filter: brightness(1.06); }

  .poster {
    position: relative; overflow: hidden; isolation: isolate;
    background: linear-gradient(180deg, var(--bg-soft), var(--bg));
    border: 1px solid var(--line); border-radius: 28px;
    padding: 52px 44px 34px; margin-bottom: 40px;
  }
  .poster .streaks { position: absolute; inset: -10px -20px auto; height: 230px; opacity: .55; z-index: 0; }
  .poster .streaks svg { width: 100%; height: 100%; }
  .poster .num26 { position: absolute; right: -8px; top: -22px; font: 900 italic clamp(100px, 18vw, 220px)/1 var(--font);
    color: transparent; -webkit-text-stroke: 2px var(--gold-soft); z-index: 0; pointer-events: none; }
  .poster-head, .poster-podium, .poster-list { position: relative; z-index: 1; }

  .poster-head { text-align: center; }
  .poster-head .kicker { display: block; }
  .poster-h1 { font-size: clamp(38px, 6.6vw, 68px); font-weight: 900; letter-spacing: -.03em; line-height: .95; margin: 10px 0 4px; }
  .poster-h1 em { color: var(--gold); font-style: italic; }
  .poster-sub { color: var(--text-dim); font-size: 14px; margin: 0; }

  .poster-podium { display: flex; align-items: flex-end; justify-content: center; gap: 22px; margin: 40px 0 34px; }
  .pp { flex: 1; max-width: 240px; text-align: center; }
  .pp-trophy { margin-bottom: 6px; display: flex; justify-content: center; filter: drop-shadow(0 6px 16px rgba(232,198,106,.4)); }
  .pp-name { font-weight: 700; font-size: 16px; }
  .pp-pts { font-weight: 900; color: var(--gold); font-size: 30px; line-height: 1.1; }
  .pp-pts span { font-size: 12px; color: var(--text-dim); font-weight: 700; margin-left: 3px; }
  .pp-base { height: var(--h); margin-top: 8px; border-radius: 16px 16px 0 0; position: relative;
    background: linear-gradient(180deg, color-mix(in srgb, var(--medal) 22%, var(--bg-soft)), var(--bg-soft));
    border: 1px solid var(--line); border-top: 3px solid var(--medal);
    box-shadow: inset 0 18px 40px -28px var(--medal); display: flex; align-items: flex-start; justify-content: center; }
  .pp:first-child .pp-base { box-shadow: inset 0 18px 40px -22px var(--medal), 0 0 50px -16px var(--gold-soft); }
  .pp-rank { font-weight: 900; font-size: 26px; color: var(--medal); margin-top: 10px; opacity: .9; }

  .poster-list { list-style: none; margin: 0; padding: 16px 0 0; border-top: 1px solid var(--line); display: flex; flex-direction: column; gap: 4px; }
  .pr { display: flex; align-items: center; gap: 12px; padding: 11px 16px; border-radius: 12px; }
  .pr:nth-child(even) { background: var(--surface); }
  .pr-rk { width: 26px; font-weight: 900; font-size: 17px; color: var(--text-dim); text-align: center; }
  .pr-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); flex: 0 0 auto; }
  .pr-nm { flex: 1; font-weight: 700; font-size: 15px; }
  .pr-pt { font-weight: 900; font-size: 16px; color: var(--gold); }
  .pr-pt small { font-weight: 700; font-size: 10px; color: var(--text-dim); }

  @media print {
    :global(body > header), :global(body > footer), .no-print { display: none !important; }
    :global(html), :global(body) { background: var(--bg) !important; }
    :global(main.container) { width: 100% !important; max-width: none !important; padding: 0 !important; margin: 0 !important; }
    * { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    .poster { border-radius: 0; border: 0; padding: 10mm 12mm; margin: 0; height: 277mm; display: flex; flex-direction: column; justify-content: center; }
    .poster-podium { margin: 30px 0 26px; }
  }
  @page { size: A4; margin: 10mm; }
</style>
