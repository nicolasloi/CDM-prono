---
const { items = [] } = Astro.props;
---
{items.length > 0 && (
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px">
    {items.map((b) => (
      <div class="pill" style="padding:14px;border-radius:var(--radius-card)">
        <div class="kicker">{b.label}</div>
        <div style="font-weight:800;margin-top:4px">{b.name}</div>
        <div class="dim" style="font-size:11px">{b.hint}</div>
      </div>
    ))}
  </div>
)}
